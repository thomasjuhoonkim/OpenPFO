FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      boundaries;
}

// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

front
{
    type            empty;
}
back
{
    type            empty;
}
bottom
{
    type            symmetryPlane;
}
defaultFaces
{
    type            empty;
}

