FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      T;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

#include        "include/initialConditions"

dimensions      [0 0 0 1 0 0 0];

internalField   uniform $T;

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           uniform $T;
    }
    outlet
    {
        type            zeroGradient;
    }
    walls
    {
        type           fixedValue;
        value          uniform $Twall;
    }
    #include "include/boundaries"
}

