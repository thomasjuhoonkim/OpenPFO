FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      p;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

#include "include/initialConditions"

dimensions      [1 -1 -2 0 0 0 0];

internalField   uniform $pressureInlet;

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           uniform $pressureInlet;
    }
    outlet
    {
         type           waveTransmissive;
        field           p;             
        psi             thermo:psi;     
        gamma           $Y_Air;        
        value           uniform $pressureInlet; 
    }
    walls
    {
        type            zeroGradient;
    }
    #include "include/boundaries"
}


